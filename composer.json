{
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.5",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "doctrine/doctrine-bundle": "^3.2.2",
        "doctrine/doctrine-migrations-bundle": "^4",
        "doctrine/orm": "^3.6.2",
        "phpdocumentor/reflection-docblock": "^5.6.6",
        "phpstan/phpdoc-parser": "^2.3.2",
        "symfony/console": "^8.0.4",
        "symfony/dotenv": "^8.0",
        "symfony/expression-language": "^8.0.4",
        "symfony/flex": "^2.10.0",
        "symfony/form": "^8.0.4",
        "symfony/framework-bundle": "^8.0.5",
        "symfony/http-client": "^8.0.5",
        "symfony/intl": "^8.0.4",
        "symfony/mailer": "^8.0.4",
        "symfony/mime": "^8.0.5",
        "symfony/monolog-bundle": "^4.0.1",
        "symfony/notifier": "^8.0.4",
        "symfony/process": "^8.0.5",
        "symfony/property-access": "^8.0.4",
        "symfony/property-info": "^8.0.5",
        "symfony/runtime": "^8.0.1",
        "symfony/serializer": "^8.0.5",
        "symfony/string": "^8.0.4",
        "symfony/translation": "^8.0.4",
        "symfony/twig-bundle": "^8.0.4",
        "symfony/validator": "^8.0.5",
        "symfony/web-link": "^8.0.4",
        "symfony/yaml": "^8.0.1",
        "twig/extra-bundle": "^2.12|^3.23.0",
        "twig/twig": "^3.23.0",
        "knplabs/knp-paginator-bundle": "^6.10.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0.3",
        "symfony/browser-kit": "^8.0.4",
        "symfony/css-selector": "^8.0",
        "symfony/debug-bundle": "^8.0",
        "symfony/maker-bundle": "^1.66.0",
        "symfony/stopwatch": "^8.0",
        "symfony/web-profiler-bundle": "^8.0.4",
        "phpstan/extension-installer": "^1.4.3",
        "phpstan/phpstan": "^2.1.39",
        "phpstan/phpstan-doctrine": "^2.0.16",
        "phpstan/phpstan-symfony": "^2.0.14",
        "php-cs-fixer/shim": "^3.94.0",
        "rector/rector": "^2.3.6",
        "vincentlanglet/twig-cs-fixer": "^3.13.0"
    },
    "config": {
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": false,
        "bump-after-update": true,
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true,
            "phpstan/extension-installer": true
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*",
        "symfony/polyfill-php83": "*",
        "symfony/polyfill-php84": "*"
    },
    "scripts": {
        "lint:rector": "rector process",
        "lint:php-cs-fixer": "php-cs-fixer fix -v",
        "lint:twig-cs-fixer": "twig-cs-fixer lint --fix",
        "lint": [
            "rector process",
            "php-cs-fixer fix -v",
            "twig-cs-fixer lint --fix"
        ],
        "test:container": "bin/console lint:container",
        "test:php-cs-fixer": "php-cs-fixer fix -v --dry-run",
        "test:phpstan": "phpstan analyse --ansi --memory-limit=-1",
        "test:twig-cs-fixer": "twig-cs-fixer lint",
        "test:rector": "rector process --dry-run",
        "test:doctrine-schema": "bin/console doctrine:schema:validate --skip-sync",
        "test:yaml": "bin/console lint:yaml config/ src/",
        "test:twig": "bin/console lint:twig src/ templates/ --show-deprecations",
        "test": [
            "bin/console lint:container",
            "php-cs-fixer fix -v --dry-run",
            "phpstan analyse --ansi --memory-limit=-1",
            "twig-cs-fixer lint",
            "rector process --dry-run",
            "bin/console doctrine:schema:validate --skip-sync",
            "bin/console lint:yaml config/ src/",
            "bin/console lint:twig src/ templates/ --show-deprecations"
        ],
        "auto-scripts": {
            "cache:clear": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "^8.0"
        }
    }
}
